# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# Required — Flask session signing key. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-random-64-char-hex-string

# Optional — defaults to SQLite
# DATABASE_URI=postgresql://user:password@localhost/siem_db
DATABASE_URI=sqlite:///siem.db

# Optional — network binding
APP_HOST=0.0.0.0
APP_PORT=8050
APP_DEBUG=false
